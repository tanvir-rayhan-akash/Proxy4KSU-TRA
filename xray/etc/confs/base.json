{
    "log": {
        "access": "none",
        "loglevel": "warning",
        "dnsLog": false
    },
    "inbounds": [
        {
            "tag": "proxy-in",
            "port": 65535,
            "protocol": "dokodemo-door",
            "settings": {
                "network": "tcp,udp",
                "followRedirect": true,
                "bufferSize": 16384
            },
            "streamSettings": {
                "sockopt": {
                    "tproxy": "tproxy",
                    "tcpFastOpen": true,
                    "tcpKeepAliveInterval": 60,
                    "tcpKeepAliveIdle": 300,
                    "tcpNoDelay": true,
                    "tcpMptcp": false,
                    "mark": 255
                }
            },
            "sniffing": {
                "enabled": true,
                "destOverride": [
                    "http",
                    "tls",
                    "quic"
                ],
                "metadataOnly": true,
                "routeOnly": true
            }
        },
        {
            "tag": "socks-in",
            "listen": "127.0.0.1",
            "port": 65534,
            "protocol": "socks",
            "settings": {
                "udp": true,
                "auth": "noauth"
            },
            "streamSettings": {
                "sockopt": {
                    "tcpFastOpen": true,
                    "tcpNoDelay": true
                }
            },
            "sniffing": {
                "enabled": true,
                "destOverride": [
                    "http",
                    "tls",
                    "quic"
                ],
                "metadataOnly": true,
                "routeOnly": true
            }
        }
    ]
}
